# Ronda Diária - Variáveis de Ambiente

# URL completa de conexão com o banco de dados (se usada)
DATABASE_URL=

# Configurações individuais do PostgreSQL (usadas se DATABASE_URL estiver vazia)
DB_HOST=postgres
DB_PORT=5432
DB_USER=myuser
DB_PASSWORD=mypassword
DB_NAME=mydb

# Porta do servidor Express
PORT=3000

# Chave de API para busca de notícias (Serper API)
SERPER_API_KEY=

# Chave de API para resumo via DeepSeek (opcional / fallback)
DEEPSEEK_API_KEY=

# Chave de API para resumo e sentimento via Gemini (principal)
GEMINI_API_KEY=
